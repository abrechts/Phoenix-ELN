<Window x:Class="dlgSearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CustomControls" 
        xmlns:elnCoreModel="clr-namespace:ElnCoreModel;assembly=ElnCoreModel" 
        xmlns:scm ="clr-namespace:System.ComponentModel;assembly=WindowsBase" xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Substructure Search" TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" 
        Width="780" Height="1000" MinHeight="800" MaxWidth="850" MinWidth="760" Background="#FF3D3C3C" SizeToContent="Height" >

    <Window.Resources>

        <DataTemplate x:Key="expTreeItem">
            <local:RssItemGroup/>
        </DataTemplate>

        <local:BooleanInvertConverter x:Key="boolInvertConv"/>

        <CollectionViewSource x:Key="UsersView" CollectionViewType="{x:Type ListCollectionView}"/>
        <CollectionViewSource x:Key="ProjectsView" CollectionViewType="{x:Type ListCollectionView}"/>
        <CollectionViewSource x:Key="ProjFoldersView" CollectionViewType="{x:Type ListCollectionView}"/>

        <local:IntegerToBooleanConverter x:Key="IntToBooleanConv"/>

        <Style x:Key="ListBoxNoHighlight" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="left" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>

        <StackPanel>

            <StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,4">

                    <TextBlock Text="Find Reactions" FontWeight="Bold"  HorizontalAlignment="Center" FontStyle="Italic" 
                       FontSize="13" Foreground="LightBlue"/>

                    <ContentControl x:Name="icoInfo" Content="{StaticResource icoInfo}" Cursor="Hand" Height="14" Margin="6,1,0,0"/>

                </StackPanel>

                <Border Grid.Row="1" Background="transparent" BorderBrush="#FFADADAD" BorderThickness="1" Margin="12,0,12,12" CornerRadius="6" >

                    <Grid >

                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="135*"/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="120*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="0" Margin="6,8,4,0" VerticalAlignment="Center" >
                            
                            <!--<StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                                <RadioButton x:Name="rdoLocal" IsChecked="True" Content="Local search" Foreground="white" Margin="2,0,4,2"/>
                                <RadioButton x:Name="rdoServer" Content="Server search"  Foreground="white" Margin="2,0,0,0"/>
                            </StackPanel>-->

                            <!-- users ComboBox --> 
                            
                            <ComboBox x:Name="cboUsers" Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,5" 
                                SelectedIndex="0" MinWidth="100" VerticalContentAlignment="Center" >
                                
                                <ComboBox.ItemsSource>
                                    <CompositeCollection>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ContentControl Content="{StaticResource icoUser2_dark}"  Width="16"/>
                                            <TextBlock Text="All Users" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="white"/>
                                        </StackPanel>
                                        <Separator Background="LightGray" Height="0.8" Margin="0,-3"/>
                                        <CollectionContainer Collection="{Binding Source={StaticResource UsersView}}"/>
                                    </CompositeCollection>
                                </ComboBox.ItemsSource>
                                
                                <ComboBox.Resources>
                                    <DataTemplate DataType="{x:Type sys:String}">
                                        <StackPanel Orientation="Horizontal" Margin="0,-2,0,0" >
                                            <ContentControl Content="{StaticResource icoUser2_dark}" Width="16"/>
                                            <TextBlock Text="{Binding}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.Resources>
                                
                            </ComboBox>

                            <!-- projects ComboBox -->

                            <ComboBox x:Name="cboProjects" Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,5"
                               SelectedIndex="0">

                                <ComboBox.ItemsSource>
                                    <CompositeCollection>
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{StaticResource icoFolderClosed}" Width="16"/>
                                            <TextBlock Text="All Projects" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="white"/>
                                        </StackPanel>
                                        <Separator Background="LightGray" Height="0.8" Margin="0,-3"/>
                                        <CollectionContainer Collection="{Binding Source={StaticResource ProjectsView}}"/>
                                    </CompositeCollection>
                                </ComboBox.ItemsSource>

                                <ComboBox.Resources>
                                    <DataTemplate DataType="{x:Type sys:String}">
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{StaticResource icoFolderClosed}" Width="16"/>
                                            <TextBlock Text="{Binding}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.Resources>

                            </ComboBox>

                            <!-- project group ComboBox -->

                            <ComboBox x:Name="cboProjGroups" Style="{StaticResource DarkComboBoxStyle}" SelectedIndex="0" 
                               IsEnabled="{Binding ElementName=cboProjects, Path=SelectedIndex, Converter={StaticResource IntToBooleanConv}}" Margin="0,0,0,6">

                                <ComboBox.ItemsSource>
                                    <CompositeCollection>
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{StaticResource icoGrayDot}" Width="16" HorizontalAlignment="Left" Margin="0,1,0,0"/>
                                            <TextBlock Text="All Groups" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="white"/>
                                        </StackPanel>
                                        <Separator Background="LightGray" Height="0.8" Margin="0,-3"/>
                                        <CollectionContainer Collection="{Binding Source={StaticResource ProjFoldersView}}"/>
                                    </CompositeCollection>
                                </ComboBox.ItemsSource>

                                <ComboBox.Resources>
                                    <DataTemplate DataType="{x:Type sys:String}">
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{StaticResource icoFolderClosed}" Width="16"/>
                                            <TextBlock Text="{Binding}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.Resources>

                            </ComboBox>

                            <!--<StackPanel Orientation="Horizontal" Margin="0,8,0,8" HorizontalAlignment="Center">
                                <RadioButton x:Name="rdoLocal" Content="Local Search" Foreground="white" Margin="2,0,5,2" 
                                    Padding="1,0,0,0" VerticalContentAlignment="center"/>
                                <RadioButton x:Name="rdoServer" Content="Server Search"  Foreground="white" Margin="2,0,0,0"
                                    Padding="1,0,0,0" VerticalContentAlignment="center"/>
                            </StackPanel>-->

                        </StackPanel>

                        <Border Grid.Column="2" Grid.Row="1" CornerRadius="6" BorderBrush="#FF54A2D1" BorderThickness="1" Padding="3"  
                           VerticalAlignment="Top" Margin="0,6,0,6" Width="420" Height="150">
                            <local:SketchAreaRSS x:Name="pnlQuerySketch" ReactionSketch="{Binding}" Margin="4,2,4,2"/>
                        </Border>

                        <StackPanel Grid.Column="3" Grid.Row="1" Margin="6,0,6,0" VerticalAlignment="Center" HorizontalAlignment="center">

                            <!--yield filter-->
                            
                            <Border BorderBrush="#FF01ABE3" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,6,0,4" Background="Transparent" >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    
                                    <TextBlock Text="Yield >=" FontWeight="DemiBold" Foreground="lightblue" Margin="0,0,3,0"/>
                                    <local:NumericTextBox x:Name="txtYield" IntegersOnly="true" PositiveNumbersOnly="True" d:Text="56" MinWidth="36"
                                        Margin="0,0,2,0" HorizontalContentAlignment="Center" CaretBrush="White" Foreground="white" Background="Transparent" 
                                        BorderThickness="1" BorderBrush="lightgray" VerticalContentAlignment="Center" Padding="0,-1,0,0" />
                                    <TextBlock Text="%" Margin="1,0,0,0" VerticalAlignment="Center" Foreground="white"/>
                                    
                                </StackPanel>
                                
                            </Border>

                            <!--scale filter-->
                            
                            <Border BorderBrush="#FF01ABE3" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,0,10" Background="transparent">
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    
                                    <TextBlock Text="Scale >=" FontWeight="DemiBold" Foreground="lightBlue" Margin="2,0,3,0" />
                                    <local:NumericTextBox x:Name="txtScale" SignificantDigits="3" PositiveNumbersOnly="True" d:Text="200" MinWidth="46" Margin="0,0,2,0" 
                                        HorizontalContentAlignment="Center" CaretBrush="White" Foreground="white" Background="Transparent" BorderThickness="1"
                                        BorderBrush="lightgray" VerticalContentAlignment="Center" Padding="0,-1,0,0"/>
                                    <TextBlock Text="g" Margin="2,0,2,0" VerticalAlignment="Center" Foreground="white"/>
                                    
                                </StackPanel>
                                
                            </Border>

                            <CheckBox x:Name="chkServerSearch" Content="Server Search" Foreground="white" HorizontalAlignment="Center"/>

                            <Button x:Name="btnSearch" Content="Search" HorizontalAlignment="left" Padding="20,2,20,3" Margin="24,10,0,4"/>
                            
                        </StackPanel>

                    </Grid>

                </Border>

            </StackPanel>

            <Border  Margin="160,0,0,14" >

                <StackPanel>

                    <TextBlock x:Name="blkResultsTitle" Text="Results" HorizontalAlignment="Left" FontWeight="Bold" 
                        FontSize="13" Foreground="LightBlue" FontStyle="Italic" d:Visibility="visible" Visibility="collapsed" Margin="180,0,0,2" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MinHeight="80">

                        <ListBox x:Name="lstRssHitGroups" ItemsSource="{Binding}" ItemTemplate="{StaticResource expTreeItem}" BorderThickness="0"
                            ItemContainerStyle="{StaticResource ListBoxNoHighlight}"  HorizontalAlignment="left" MinWidth="400"
                            HorizontalContentAlignment="left" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            d:Visibility="visible" Visibility="Collapsed"/>

                    </ScrollViewer>

                </StackPanel>

            </Border>

        </StackPanel>
        <Ellipse HorizontalAlignment="Left" Height="100" Margin="980,113,0,0" Stroke="Black" VerticalAlignment="Top" Width="100"/>

    </Grid>
</Window>
