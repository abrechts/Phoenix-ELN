<Window x:Class="dlgSearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CustomControls" 
        xmlns:elnCoreModel="clr-namespace:ElnCoreModel;assembly=ElnCoreModel" 
        xmlns:scm ="clr-namespace:System.ComponentModel;assembly=WindowsBase" xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Substructure Search" TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" 
        MaxHeight="800" MaxWidth="690" MinWidth="690" Background="#FF3D3C3C" SizeToContent="Height" >

    <Window.Resources>

        <DataTemplate x:Key="expTreeItem">
            <local:RssItemGroup/>
        </DataTemplate>

        <!--Sortable view of user entity data-->
        <CollectionViewSource x:Key="UsersView" CollectionViewType="{x:Type ListCollectionView}"/>

        <!--Sortable view of project entity data-->
        <CollectionViewSource x:Key="ProjectsView" CollectionViewType="{x:Type ListCollectionView}"/>

        <Style x:Key="ListBoxNoHighlight" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="left" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>


    </Window.Resources>

    <Grid>

        <StackPanel>

            <StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,4">

                    <TextBlock Text="Find Reactions" FontWeight="Bold"  HorizontalAlignment="Center" FontStyle="Italic" 
                       FontSize="13" Foreground="LightSkyblue"/>

                    <ContentControl x:Name="icoInfo" Content="{StaticResource icoInfo}" Cursor="Hand" Height="14" Margin="6,1,0,0"/>

                </StackPanel>

                <Button x:Name="btnSearch" Content="Search" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="6,0,6,1" Margin="0,0,0,4"/>

                <Border Grid.Row="1" Background="transparent" BorderBrush="#FFADADAD" BorderThickness="1" Margin="12,0,12,12" CornerRadius="6" >

                    <Grid >

                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="127*"/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="132*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" Margin="0,8,0,0" HorizontalAlignment="Center">

                            <!-- users ComboBox --> 
                            
                            <ComboBox x:Name="cboUsers" Style="{StaticResource DarkComboBoxStyle}" HorizontalAlignment="Left" Margin="0,0,4,0" 
                                SelectedIndex="0" MinWidth="100" VerticalContentAlignment="Center" >
                                
                                <ComboBox.ItemsSource>
                                    <CompositeCollection>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ContentControl Content="{StaticResource icoUser2_dark}"/>
                                            <TextBlock Text="All Users" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="white"/>
                                        </StackPanel>
                                        <Separator Background="LightGray" Height="0.8" Margin="0,-3"/>
                                        <CollectionContainer Collection="{Binding Source={StaticResource UsersView}}"/>
                                    </CompositeCollection>
                                </ComboBox.ItemsSource>
                                
                                <ComboBox.Resources>
                                    <DataTemplate DataType="{x:Type sys:String}">
                                        <StackPanel Orientation="Horizontal" Margin="0,-2,0,0" >
                                            <ContentControl Content="{StaticResource icoUser2_dark}"/>
                                            <TextBlock Text="{Binding}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.Resources>
                                
                            </ComboBox>

                            <!-- projects ComboBox -->

                            <ComboBox x:Name="cboProjects" Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,4,0" HorizontalAlignment="Left"
                               SelectedIndex="0">

                                <ComboBox.ItemsSource>
                                    <CompositeCollection>
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{StaticResource icoFolderClosed}" Height="16"/>
                                            <TextBlock Text="All Projects" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="white"/>
                                        </StackPanel>
                                        <Separator Background="LightGray" Height="0.8" Margin="0,-3"/>
                                        <CollectionContainer Collection="{Binding Source={StaticResource ProjectsView}}"/>
                                    </CompositeCollection>
                                </ComboBox.ItemsSource>

                                <ComboBox.Resources>
                                    <DataTemplate DataType="{x:Type sys:String}">
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{StaticResource icoFolderClosed}" Height="16"/>
                                            <TextBlock Text="{Binding}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.Resources>

                            </ComboBox>

                            <!-- project group ComboBox -->

                            <ComboBox x:Name="cboProjGroup" Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,4,0" HorizontalAlignment="Left">
                                <CompositeCollection>
                                    <ComboBoxItem Content="All Groups" IsSelected="True"/>
                                    <Separator Background="LightGray" Height="0.8" Margin="0,-3"/>
                                    <CollectionContainer Collection="{Binding UserGroups}"/>
                                </CompositeCollection>
                            </ComboBox>

                        </StackPanel>

                        <Border Grid.Column="2" Grid.Row="1" CornerRadius="6" BorderBrush="#FF54A2D1" BorderThickness="1" Padding="3" HorizontalAlignment="Center" 
                           VerticalAlignment="Top" Margin="0,6,0,6" Width="400" Height="150">
                            <local:SketchAreaRSS x:Name="pnlQuerySketch" ReactionSketch="{Binding}" Margin="4,2,4,2"/>
                        </Border>

                        <StackPanel Grid.Column="3" Grid.Row="1" Margin="6,0,6,0" VerticalAlignment="Center" >

                            <RadioButton x:Name="rdoLocal" IsChecked="True" Content="Local search" Foreground="white" Margin="0,0,0,2"/>
                            <RadioButton x:Name="rdoServer" Content="Server search"  Foreground="white"/>

                        </StackPanel>

                    </Grid>

                </Border>

            </StackPanel>

            <Border HorizontalAlignment="center" Margin="0,0,0,14" >

                <StackPanel>

                    <TextBlock x:Name="blkResultsTitle" Text="Results" HorizontalAlignment="Center" FontWeight="Bold" 
                        FontSize="13" Foreground="LightBlue" FontStyle="Italic" d:Visibility="visible" Visibility="collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MinHeight="80">

                        <ListBox x:Name="lstRssHitGroups" ItemsSource="{Binding}" ItemTemplate="{StaticResource expTreeItem}" BorderThickness="0"
                            ItemContainerStyle="{StaticResource ListBoxNoHighlight}"  HorizontalAlignment="left" MinWidth="400"
                            HorizontalContentAlignment="left" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            d:Visibility="visible" Visibility="Collapsed"/>

                    </ScrollViewer>

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>
</Window>
